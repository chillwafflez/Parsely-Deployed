@base = http://localhost:5180

### List recent documents
GET {{base}}/api/documents

### Get a document by id
GET {{base}}/api/documents/REPLACE_WITH_GUID

### Download original file
GET {{base}}/api/documents/REPLACE_WITH_GUID/file

### List templates (grab a TemplateId for the voice/fill request below)
GET {{base}}/api/templates

### Get a template by id (inspect Hint + Aliases on each rule)
GET {{base}}/api/templates/REPLACE_WITH_TEMPLATE_GUID

### Update a template (metadata + rules reconcile). Omit any rule id from
### the Rules array to delete that rule. Sending an id that doesn't belong
### to this template returns 400.
PUT {{base}}/api/templates/REPLACE_WITH_TEMPLATE_GUID
Content-Type: application/json

{
  "name": "Acme Invoice (edited)",
  "description": "Updated notes",
  "kind": "Invoice",
  "vendorHint": "Acme Corp",
  "rules": [
    {
      "id": "REPLACE_WITH_RULE_GUID",
      "name": "InvoiceTotal",
      "dataType": "currency",
      "isRequired": true,
      "hint": "The grand total at the bottom",
      "aliases": ["total", "grand total"]
    }
  ]
}

### Duplicate a template (clones template + all rules with new ids,
### appends " (copy)" to the name, resolves collisions).
POST {{base}}/api/templates/REPLACE_WITH_TEMPLATE_GUID/duplicate


### ----- Voice: mint a short-lived Azure Speech JWT for the browser -----
# Requires Speech:Key + Speech:Region via dotnet user-secrets.
GET {{base}}/api/voice/token

### ----- Voice: map a transcript to structured field patches -----
# Requires OpenAI:Key (+ optional OpenAI:Endpoint for Azure) via dotnet user-secrets.
# Replace TemplateId with the id from the templates list above.
POST {{base}}/api/voice/fill
Content-Type: application/json

{
  "templateId": "REPLACE_WITH_TEMPLATE_GUID",
  "transcript": "For the customer name put Jane Doe, the purchase order is P.O. 2302, and the invoice total is one hundred twenty five dollars",
  "currentValues": {}
}

### ----- Voice: with existing field values for disambiguation context -----
POST {{base}}/api/voice/fill
Content-Type: application/json

{
  "templateId": "REPLACE_WITH_TEMPLATE_GUID",
  "transcript": "Change the tax to fifteen dollars",
  "currentValues": {
    "InvoiceTotal": "125.00",
    "VendorName": "Acme Corp"
  }
}
