{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm start)",
      "Bash(pnpm test:*)",
      "Bash(pnpm --dir web:*)",
      "Bash(pnpm -C web:*)",

      "Bash(next lint:*)",
      "Bash(next build:*)",
      "Bash(npx next:*)",

      "Bash(dotnet restore)",
      "Bash(dotnet restore:*)",
      "Bash(dotnet build)",
      "Bash(dotnet build:*)",
      "Bash(dotnet run)",
      "Bash(dotnet run:*)",
      "Bash(dotnet test)",
      "Bash(dotnet test:*)",
      "Bash(dotnet watch:*)",
      "Bash(dotnet user-secrets list)",
      "Bash(dotnet user-secrets list:*)",
      "Bash(dotnet ef migrations:*)",
      "Bash(dotnet ef database update:*)",
      "Bash(dotnet ef database drop:*)",
      "Bash(dotnet --info)",
      "Bash(dotnet --version)",

      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git remote -v)",
      "Bash(git remote:*)",
      "Bash(git ls-remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git config --get:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list)",

      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat package.json)",
      "Bash(cat pnpm-lock.yaml)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(file:*)",
      "Bash(wc:*)",

      "Bash(rm -rf web/.next)",
      "Bash(rm -rf web/.next:*)",
      "Bash(rm -rf api/bin)",
      "Bash(rm -rf api/obj)",

      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./web/.env)",
      "Read(./web/.env.*)",
      "Read(./api/appsettings.Development.json)",
      "Read(./api/secrets.json)",
      "Read(./samples/**)",
      "Read(./Document Parsing Service Prototype-handoff/**)",

      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout --:*)",
      "Bash(git rebase:*)",
      "Bash(git branch -D:*)",

      "Bash(dotnet user-secrets set:*)",
      "Bash(dotnet user-secrets clear:*)",
      "Bash(dotnet user-secrets remove:*)",

      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ..:*)",

      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
